# ─────────────────────────────────────────────────────────
#  IOX Backend — variables d'environnement
# ─────────────────────────────────────────────────────────
#  Copier ce fichier en `apps/backend/.env` puis renseigner.
#
#  ⚠  Les valeurs ci-dessous sont SEULEMENT POUR LE DÉVELOPPEMENT LOCAL.
#     En staging/production, le backend REFUSE de démarrer si :
#       - un secret de démo est détecté (JWT_SECRET, MINIO_SECRET_KEY…)
#       - JWT_SECRET === JWT_REFRESH_SECRET
#       - JWT_SECRET fait moins de 32 caractères
#     Générer des secrets forts : `openssl rand -hex 48`
# ─────────────────────────────────────────────────────────

# ── APP ───────────────────────────────────────────────────
APP_ENV="development"           # development | test | staging | production
APP_PORT="3001"
FRONTEND_URL="http://localhost:3000"
# Optionnel : origines CORS supplémentaires (CSV). Utile pour un domaine admin
# distinct ou des URLs de preview (Vercel, Netlify). FRONTEND_URL est toujours
# autorisé, inutile de le répéter ici.
# FRONTEND_URLS="https://admin.iox.example,https://preview-abc.iox.example"
# Optionnel : limite de taille des bodies JSON/urlencoded. Défaut 2mb.
# BODY_SIZE_LIMIT="2mb"

# ── DATABASE ──────────────────────────────────────────────
# Port 5434 correspond à docker-compose.yml (5434:5432)
DATABASE_URL="postgresql://iox:iox_password@localhost:5434/iox_dev"

# ── REDIS (optionnel) ─────────────────────────────────────
# Port 6381 correspond à docker-compose.yml (6381:6379)
REDIS_URL="redis://localhost:6381"

# ── AUTH — JWT ────────────────────────────────────────────
# ⚠ REMPLACER en préprod/prod. Générer : `openssl rand -hex 48`
# Les deux secrets DOIVENT être différents.
JWT_SECRET="dev-only-jwt-secret-remplace-moi-avec-openssl-rand-hex-48"
JWT_REFRESH_SECRET="dev-only-refresh-secret-different-du-jwt-et-32-chars-min"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── MINIO (stockage documents) ────────────────────────────
# ⚠ `minioadmin` est interdit en préprod/prod — change les deux clés.
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="iox-documents"
MINIO_USE_SSL="false"

# ── MAIL (optionnel, notifications) ───────────────────────
# MailHog local : localhost:1025, UI http://localhost:8025
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="noreply@iox.mch"

# ── OBSERVABILITÉ (optionnel) ─────────────────────────────
# Si défini, /api/v1/metrics exige `Authorization: Bearer <METRICS_TOKEN>`.
# Sinon l'endpoint est public (OK en réseau privé / mesh k8s interne).
# METRICS_TOKEN=""
#
# Cadence (ms) de rafraîchissement des gauges marketplace via OpsMetricsService.
# Défaut 60000 (1 min), min 10000 pour éviter le hammering Postgres.
# IOX_OPS_METRICS_INTERVAL_MS="60000"
