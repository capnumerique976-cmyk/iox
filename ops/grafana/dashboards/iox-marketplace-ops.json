{
  "title": "IOX — Marketplace ops",
  "uid": "iox-marketplace-ops",
  "tags": ["iox", "marketplace", "ops"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Sellers total",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "iox_marketplace_sellers_total", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sellers en attente",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "iox_marketplace_sellers_by_status{status=\"pending_review\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sellers suspendus",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "iox_marketplace_sellers_by_status{status=\"suspended\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Review pending",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "iox_marketplace_review_pending", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Docs rejetés",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "iox_marketplace_documents{verification_status=\"rejected\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "RFQ NEW",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "iox_marketplace_rfq{status=\"new\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Publications (published vs in_review)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "iox_marketplace_publications",
          "legendFormat": "{{entity}} / {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Review queue backlog",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "iox_marketplace_review_pending", "refId": "A" }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Documents par statut",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "iox_marketplace_documents",
          "legendFormat": "{{verification_status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "RFQ funnel",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "iox_marketplace_rfq",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "stat",
      "title": "Dernier refresh gauges (âge)",
      "description": "Doit rester < 90 s. Au-delà : OpsMetricsService KO.",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "time() - iox_marketplace_metrics_last_refresh_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      }
    }
  ]
}
